generator client {
  provider = "prisma-client-js"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Stream {
  id         String   @id @default(cuid())
  trackId    String
  trackName  String
  artistName String
  artistArt  String?
  albumName  String
  albumArt   String?
  durationMs Int
  playedAt   DateTime
  /// Synthetic `/demo` preview rows; real imports/sync set false.
  isDemo     Boolean  @default(false)

  @@unique([trackId, playedAt])
  @@index([playedAt])
  @@index([artistName])
  @@index([isDemo])
}
