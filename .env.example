# Soundfolio — copy to .env and fill in. Never commit .env
#
# --- PostgreSQL (required) ---
# Cloud: usually add ?sslmode=require
# Example (Neon): postgresql://user:pass@ep-xxx.region.aws.neon.tech/neondb?sslmode=require
DATABASE_URL="postgresql://user:password@HOST:5432/DATABASE?sslmode=require"
# Optional: some hosts use this for migrations only; else match DATABASE_URL or omit
DIRECT_URL="postgresql://user:password@HOST:5432/DATABASE?sslmode=require"

# --- Last.fm (required for scrobble sync) ---
# API key: https://www.last.fm/api/account/create
# Username: the name in your profile URL — https://www.last.fm/user/THIS_PART
LASTFM_API_KEY=""
LASTFM_USER=""

# IANA timezone for charts (hour of day, day of week, daily buckets). Required on many hosts
# (e.g. Netlify) where the server runs in UTC — set to where you actually listen, e.g. America/New_York
# TIMEZONE="America/Los_Angeles"

# Optional: protect /me routes with a secret key (query ?key=... or cookie)
AUTH_KEY=""
